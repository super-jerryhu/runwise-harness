{
  "name": "runwise-harness",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "runwise-harness",
      "version": "0.0.0",
      "license": "Apache-2.0",
      "workspaces": [
        "packages/*"
      ],
      "bin": {
        "runwise": "packages/cli/bin/runwise.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@runwise/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@runwise/harness-core": {
      "resolved": "packages/core",
      "link": true
    },
    "packages/cli": {
      "name": "@runwise/cli",
      "version": "0.0.0",
      "license": "Apache-2.0",
      "bin": {
        "runwise": "bin/runwise.js"
      }
    },
    "packages/core": {
      "name": "@runwise/harness-core",
      "version": "0.0.0",
      "license": "Apache-2.0"
    }
  }
}
